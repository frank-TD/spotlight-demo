# Optional CDN base for media (video) assets. Leave empty to serve from
# Next.js /public (the default for local dev and the placeholder demo).
# When the backend takes over hosting, point this at your bucket/CDN — local
# paths like /videos/hero/clip.mp4 resolve to <NEXT_PUBLIC_VIDEO_CDN>/videos/...
# Example: https://cdn.spotlight.app
NEXT_PUBLIC_VIDEO_CDN=
